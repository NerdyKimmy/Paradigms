-- Розбити заданий список на кілька списків за значеннями факторіалів (1!, 2!, 3! і т.д.)
module Main where

-- Генеруємо нескінченний список факторіалів: [1, 2, 6, 24, 120, ...]
factorials :: [Int]
factorials = scanl1 (*) [1..]

-- Допоміжна рекурсивна функція для розбиття списку
splitByFactorialsHelper :: [Int] -> [Int] -> [[Int]]
splitByFactorialsHelper [] _ = []  -- Якщо чисел не залишилось, зупиняємось
splitByFactorialsHelper nums (f:fs) =
  let currentList = filter (< f) nums     -- Елементи, менші за поточний факторіал
      remainingNums = filter (>= f) nums  -- Елементи, що не потрапили у currentList
  in currentList : splitByFactorialsHelper remainingNums fs
splitByFactorialsHelper _ [] = []         -- Для повноти паттерн-матчингу

-- Основна функція, яка запускає процес розбиття
splitByFactorials :: [Int] -> [[Int]]
splitByFactorials nums = splitByFactorialsHelper nums factorials

-- Безпечне зчитування цілих чисел
safeRead :: String -> Maybe Int
safeRead s = case reads s of
  [(num, "")] -> Just num
  _           -> Nothing

-- Функція обробки вводу-виводу
processInput :: IO ()
processInput = do
  putStrLn "Введіть список цілих чисел через пробіл:"
  inputList <- getLine
  
  let maybeList = mapM safeRead (words inputList)
  
  case maybeList of
    Just list -> do
      putStrLn "Результат розбиття списку за факторіалами:"
      print (splitByFactorials list)
      
    Nothing -> do
      putStrLn "Помилка, будь ласка, введіть тільки цілі числа через пробіл."
      processInput

main :: IO ()
main = processInput
